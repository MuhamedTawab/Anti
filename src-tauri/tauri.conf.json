{
  "productName": "Blaze",
  "version": "1.0.0",
  "identifier": "com.blaze.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "distDir": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Blaze Desktop",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.blaze.desktop",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
